import Mathlib

/-!
# Definitions for the Problem 27(b) counterexample (FROZEN)

This file is **frozen** after the SETUP stage: every object needed to *state* the
four theorems of `Theorems.lean` lives here, and nothing in this file may change
during the proving phase. All later work goes in `Prob27b/Proofs/`.

The base ring `R` is the truncated path algebra over `рќ”Ѕв‚‚ = ZMod 2` of the quiver

  e --u--> f --v--> e   (all paths of length в‰Ґ 4 are zero),

with `рќ”Ѕв‚‚`-basis `e, f, u, v, p = uv, q = vu, s = uvu, w = vuv` (dimension 8).
We realize `R` via its **left regular representation** on the 8-dimensional path
space, basis ordered `0:e 1:f 2:u 3:v 4:p 5:q 6:s 7:w`. Each path `g` becomes the
`8Г—8` matrix `L_g` over `рќ”Ѕв‚‚` of "left multiply by `g`"; associativity and the ring
axioms are then inherited from the matrix algebra (this is the point of the
matrix model вЂ” associativity is never proved by hand).
-/

namespace Prob27b

open Matrix Polynomial

/-- The ambient matrix algebra `Mв‚€(рќ”Ѕв‚‚)`. -/
abbrev Mat : Type := Matrix (Fin 8) (Fin 8) (ZMod 2)

/-! ## The four generator matrices (left regular representation)

Entry `(i, j) = 1` of `L_g` means `basisбµў = g В· basisв±ј`. -/

/-- `L_e`: vertex idempotent at `e` (fixes `e, u, p, s`; kills the rest). -/
def mE : Mat :=
  single 0 0 1 + single 2 2 1 + single 4 4 1 + single 6 6 1

/-- `L_f`: vertex idempotent at `f` (fixes `f, v, q, w`; kills the rest). -/
def mF : Mat :=
  single 1 1 1 + single 3 3 1 + single 5 5 1 + single 7 7 1

/-- `L_u`: the arrow `u : e в†’ f` (`f в†¦ u`, `v в†¦ p`, `q в†¦ s`). -/
def mU : Mat :=
  single 2 1 1 + single 4 3 1 + single 6 5 1

/-- `L_v`: the arrow `v : f в†’ e` (`e в†¦ v`, `u в†¦ q`, `p в†¦ w`). -/
def mV : Mat :=
  single 3 0 1 + single 5 2 1 + single 7 4 1

/-- The base ring `R`: the `рќ”Ѕв‚‚`-subalgebra of `Mв‚€(рќ”Ѕв‚‚)` generated by the four path
generators. Associativity etc. are inherited from `Mat`. -/
def R : Subalgebra (ZMod 2) Mat := Algebra.adjoin (ZMod 2) {mE, mF, mU, mV}

theorem mE_mem : mE в€€ R := Algebra.subset_adjoin (by simp)
theorem mF_mem : mF в€€ R := Algebra.subset_adjoin (by simp)
theorem mU_mem : mU в€€ R := Algebra.subset_adjoin (by simp)
theorem mV_mem : mV в€€ R := Algebra.subset_adjoin (by simp)

/-! ## The eight basis elements of `R`

The four generators (with their membership proofs) and the four nontrivial paths
`p, q, s, w` (as products inside the subalgebra). -/

def e : R := вџЁmE, mE_memвџ©
def f : R := вџЁmF, mF_memвџ©
def u : R := вџЁmU, mU_memвџ©
def v : R := вџЁmV, mV_memвџ©
def p : R := u * v
def q : R := v * u
def s : R := u * v * u
def w : R := v * u * v

/-- The evaluation point `aв‚Ђ = u + v` witnessing that `F В· e` is not null. -/
def aв‚Ђ : R := u + v

/-! ## Polynomials, evaluation, and the lift

`evalR r F = ОЈбµў Fбµў В· rвЃ±` substitutes the ring element `r` for the evaluation
variable, keeping coefficients on the **left** and assuming **no** commutativity
(`R` is genuinely noncommutative: `u * v = p в‰  q = v * u`). -/

/-- Left-coefficient evaluation `ОЈбµў pбµў В· rвЃ±` of a polynomial over `R` at `r : R`. -/
noncomputable def evalR (r : R) (poly : Polynomial R) : R :=
  poly.evalв‚‚ (RingHom.id R) r

/-- The null polynomial `F(X) = u XВІ + e XВі + (e+u) XвЃґ + e XвЃµ + e XвЃ¶`. The
indeterminate is the evaluation variable; the coefficients are constants in `R`.
Right multiplication by the constant `e` (the right-ideal test) is `F * C e`. -/
noncomputable def F : Polynomial R :=
  C u * X ^ 2 + C e * X ^ 3 + C (e + u) * X ^ 4 + C e * X ^ 5 + C e * X ^ 6

/-- `A = R[ПЂ]`, with the central indeterminate `ПЂ := (X : A)` playing the role of
`D = рќ”Ѕв‚‚[ПЂ]`. Concretely `A = Polynomial R` and `A / ПЂВ·A в‰… R`. -/
abbrev A : Type := Polynomial R

/-- `Ftilde` is `F` with its coefficients pushed into `A` via the constant
embedding `C : R в†’+* A`; it lives in `Polynomial A` (evaluation variable `Y`,
coefficients constant in `ПЂ`). `P := Ftilde / ПЂ` is the integer-valued polynomial. -/
noncomputable def Ftilde : Polynomial A := F.map (C : R в†’+* A)

/-! ## Problem 27's setup: `D = рќ”Ѕв‚‚[ПЂ]`, `K = Frac(D)`, `B = K вЉ—_D A`, and `Int(A)`

Problem 27 takes a torsion-free finite `D`-algebra `A` (here `A = R[ПЂ]`, with
`D = рќ”Ѕв‚‚[ПЂ] вЉ† A`), forms `K = Frac(D)` and the coefficient ring `B = K вЉ—_D A`, and
defines `Int(A) = { f в€€ B[X] : f(A) вЉ† A }`. We build all of this *literally*: the
`D`-algebra structure on `A` (`ПЂ в†¦ ПЂ`, `рќ”Ѕв‚‚ в†¦ R`), the tensor product `B`, and the
canonical embedding `A в†Є B`. -/

/-- `D = рќ”Ѕв‚‚[ПЂ]`, the base domain of Problem 27. -/
abbrev D : Type := Polynomial (ZMod 2)

/-- The `D`-algebra structure map on `A = R[ПЂ]`: apply the unit `рќ”Ѕв‚‚ в†’ R` to
coefficients (`ПЂ в†¦ ПЂ`). -/
noncomputable def algDA : D в†’+* A := Polynomial.mapRingHom (algebraMap (ZMod 2) R)

/-- The image of `D` is central in `A` (coefficients come from the central `рќ”Ѕв‚‚`,
`ПЂ` is central), so `algDA` makes `A` a `D`-algebra. -/
theorem algDA_central (d : D) (x : A) : algDA d * x = x * algDA d := by
  refine Polynomial.ext fun n => ?_
  simp only [algDA, Polynomial.coe_mapRingHom]
  rw [coeff_mul, в†ђ Finset.Nat.sum_antidiagonal_swap, coeff_mul]
  simp [coeff_map, Algebra.commutes]

/-- `A = R[ПЂ]` is a `D = рќ”Ѕв‚‚[ПЂ]`-algebra. -/
noncomputable instance instAlgebraDA : Algebra D A := algDA.toAlgebra' algDA_central

/-- `K = Frac(рќ”Ѕв‚‚[ПЂ]) = рќ”Ѕв‚‚(ПЂ)`, the fraction field of `D`. -/
abbrev K : Type := FractionRing D

/-- `B = K вЉ—_D A`, Problem 27's coefficient ring for `Int(A)`. -/
abbrev B : Type := TensorProduct D K A

/-- The canonical embedding `A в†Є B`, `a в†¦ 1 вЉ— a`. (Injective вЂ” proved in
`Proofs/Lift`.) -/
noncomputable def incA : A в†’в‚ђ[D] B := Algebra.TensorProduct.includeRight

/-- The canonical map `K в†’ B`, `k в†¦ k вЉ— 1`. -/
noncomputable def incK : K в†’+* B := Algebra.TensorProduct.includeLeftRingHom

/-- `ПЂвЃ»В№ в€€ B`: the inverse of the image of `ПЂ`, which exists because `ПЂ в‰  0` in the
domain `D` is invertible in `K = Frac(D)`. -/
noncomputable def ПЂBinv : B := incK (algebraMap D K (X : D))вЃ»В№

/-- `P = FМѓ / ПЂ в€€ B[X]`, the integer-valued polynomial of SKETCH Step 4. -/
noncomputable def Pb : Polynomial B := Polynomial.C ПЂBinv * Ftilde.map (incA : A в†’+* B)

/-- The constant polynomial `e в€€ A вЉ† B`. The product `Pb В· econstB` is what must
escape `Int(A)`. -/
noncomputable def econstB : Polynomial B := Polynomial.C (incA (C e))

/-- `g в€€ B[X]` is **integer-valued on `A`** (Problem 27's `Int(A)` membership):
`g(a) в€€ A` for every `a в€€ A`, identifying `A` with its image in `B`. -/
def IntegerValued (g : Polynomial B) : Prop := в€Ђ a : A, g.eval (incA a) в€€ Set.range incA

/-- `Int(A) = { f в€€ B[X] : f(A) вЉ† A }` (Problem 27). The conjecture claims this is
a ring; in particular it should be closed under multiplication. -/
def IntA : Set (Polynomial B) := {g | IntegerValued g}

end Prob27b
